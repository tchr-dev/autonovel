# OPTIONAL — the Claude Code pipeline does NOT need this file.
# The harness provides the LLM, so `/autonovel <tag>` runs without any keys.
#
# These variables exist only for users who run the standalone Python helpers
# in scripts/ directly against the Anthropic API (none of the shipped helpers
# currently require it; reserved for future tools).

ANTHROPIC_API_KEY=sk-ant-...
